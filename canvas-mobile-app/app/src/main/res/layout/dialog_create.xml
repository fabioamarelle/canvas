<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="4dp"
    app:strokeColor="#dfe1e6"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_create_title"
            android:textColor="#172b4d"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#fafbfc"
            app:cardCornerRadius="3dp"
            app:cardElevation="0dp"
            app:strokeColor="#dfe1e6"
            app:strokeWidth="2dp">

            <EditText
                android:id="@+id/createBoardNameInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@null"
                android:hint="@string/dialog_create_hint_name"
                android:paddingHorizontal="12dp"
                android:inputType="textCapSentences"
                android:textColor="#172b4d"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createCancelBtn"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_cancel"
                android:textAllCaps="false"
                android:textColor="#5e6c84" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/createConfirmBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:backgroundTint="#0052cc"
                android:text="@string/create_btn_create"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:cornerRadius="3dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>